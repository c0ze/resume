  "scripts": {
    "res:build": "rescript build",
    "res:clean": "rescript clean",
    "res:dev": "rescript build -w",
    "dev": "node scripts/generate-theme.mjs && npx rescript build && concurrently \"npx rescript build -w\" \"vite --config config/vite.config.ts\"",
    "build": "node scripts/build-static.mjs",
    "preview": "vite preview --config config/vite.config.ts",
    "check": "rescript build",
    "test:static": "node --test tests/static-output.test.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.268.0",
    "pdfkit": "^0.16.0",
    "pdfkit-table": "^0.1.99",
    "docx": "^9.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@rescript/core": "^1.6.0",
    "@rescript/react": "^0.13.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.19.37",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "fs-extra": "^11.3.0",
    "postcss": "^8.4.47",
    "rescript": "^11.1.0",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^8.0.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
